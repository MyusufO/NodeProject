{
  "info": {
    "name": "NodeProject - Employees",
    "description": "Employee endpoints. Run folders in numeric order (1-6): Add Employee first (auto-saves {{employeeId}}), then the rest reuse that id automatically, ending with Delete. Requires {{token}} (from the Users collection's Login request). {{roleId}} for step 5 can't be fetched via any API in this project (there's no 'list roles' endpoint) - open your roles collection in MongoDB and copy the _id of the role you want (Admin/Manager/Employee) into the environment variable manually. All routes require a Bearer token; Add/Delete/Update Role require an Admin role token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "employeeId",
      "value": ""
    },
    {
      "key": "roleId",
      "value": ""
    }
  ],
  "item": [
    {
