                  "_postman_previewlanguage": "json",
                  "header": [
                    {
                      "key": "Content-Type",
                      "value": "application/json"
                    }
                  ],
                  "body": "{\n  \"message\": \"Employee added successfully\",\n  \"employee\": {\n    \"id\": \"<mongo id - captured automatically>\",\n    \"name\": \"Alice Smith\",\n    \"email\": \"alice.smith@example.com\"\n  }\n}"
                }
              ],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// Auto-save the new employee's id for the requests below",
                      "if (pm.response.code === 201) {",
                      "    const data = pm.response.json();",
                      "    if (data.employee && data.employee.id) {",
                      "        pm.environment.set(\"employeeId\", data.employee.id);",
                      "        console.log(\"Saved employeeId:\", data.employee.id);",
                      "    }",
                      "}"
                    ]
                  }
                }
              ]
            },
