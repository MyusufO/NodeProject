      "item": [
        {
          "name": "1. Add Employee",
          "item": [
            {
              "name": "1. Add Employee - Success (Admin, single)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{token}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/employees",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "employees"
                  ]
                },
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Alice Smith\",\n  \"email\": \"alice.smith@example.com\",\n  \"phone\": \"9876500001\",\n  \"password\": \"Password123\"\n}"
                }
