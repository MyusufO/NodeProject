        {
          "name": "Search Employees",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/employees/search/filter?name=John",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "employees",
                "search",
                "filter"
              ],
              "query": [
                {
                  "key": "name",
                  "value": "John"
                }
              ]
            },
            "description": "At least one query param (name, email, phone, role, department) is required."
          },
          "response": []
        },
        {
          "name": "Update Employee Role",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/employees/role",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "employees",
                "role"
              ]
            },
            "description": "Admin only. roleId must be a valid Role document's _id (Admin/Manager/Employee).",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": \"{{employeeId}}\",\n  \"roleId\": \"REPLACE_WITH_ROLE_ID\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
