              ],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// Auto-save the created department's id for the requests below",
                      "if (pm.response.code === 201) {",
                      "    const data = pm.response.json();",
                      "    if (data._id) {",
                      "        pm.environment.set(\"departmentId\", data._id);",
                      "        console.log(\"Saved departmentId:\", data._id);",
                      "    }",
                      "}"
                    ]
                  }
                }
