{
  "info": {
    "name": "NodeProject - Leaves",
    "description": "Leave endpoints. Run folder 1 first (Apply Leave auto-saves {{leaveId}}); folder 2/3 just read. Folders 4a and 4b both act on the SAME leave and are alternatives to each other (approve vs cancel) - run one, not both, against a given leaveId, or re-run Apply Leave to get a fresh Pending leave before trying the other. Requires {{token}} and {{employeeId}} (both set by the Users collection's Register/Login requests).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "employeeId",
      "value": ""
    },
    {
      "key": "leaveId",
      "value": ""
    }
  ],
