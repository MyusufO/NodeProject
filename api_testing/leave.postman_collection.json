              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "// Auto-save the new leave's id for the requests below",
                      "if (pm.response.code === 201) {",
                      "    const data = pm.response.json();",
                      "    if (data._id) {",
                      "        pm.environment.set(\"leaveId\", data._id);",
                      "        console.log(\"Saved leaveId:\", data._id);",
                      "    }",
                      "}"
                    ]
                  }
                }
